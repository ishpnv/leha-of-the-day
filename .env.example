# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# Порт healthcheck-сервера (по умолчанию 3000)
PORT=3000

# Таймзона, в которой считается граница "дня" (по умолчанию Europe/Moscow)
BOT_TZ=Europe/Moscow

# Прокси для выхода к api.telegram.org (нужен при хостинге в РФ).
# Пусто — без прокси. Формат: socks5://[user:pass@]host:port или http://...
TELEGRAM_PROXY=

# Окружение: development | test | production
NODE_ENV=development

# --- База данных PostgreSQL ---
DB_HOST=127.0.0.1
DB_USER=telegram_user
DB_PASSWORD=telegram_pass
DB_NAME=telegram_db
# Отдельная БД для тестов (NODE_ENV=test)
DB_NAME_TEST=telegram_db_test

# Только для production. Включать SSL для подключения к БД?
# Пусто/не задано — без SSL (локальный Postgres в Docker на ВМ).
# true — для managed-баз (Supabase, Yandex Managed PostgreSQL и т.п.).
DB_SSL=
# Если DB_SSL=true: проверять ли TLS-сертификат.
# Пусто — не проверять (самоподписанный серт). true — проверять (есть валидный CA).
DB_SSL_REJECT_UNAUTHORIZED=
